# Admin credentials for /admin
CMS_ADMIN_USER=admin
CMS_ADMIN_PASSWORD="..."
SQLITE_DB_PATH="data/cms.db"

# Services
# - Supabase
PUBLIC_SUPABASE_URL="..."
PUBLIC_SUPABASE_PUBLISHABLE_KEY="..."
SUPABASE_SECRET_KEY="..."
# - Cloudflare
CLOUDFLARE_R2_ACCOUNT_ID="..."
CLOUDFLARE_R2_ACCESS_KEY_ID="..."
CLOUDFLARE_R2_SECRET_ACCESS_KEY="..."
CLOUDFLARE_R2_BUCKET="gv-hellas-media"
CLOUDFLARE_R2_PUBLIC_BASE_URL="https://media.gv-hellas.ch"
