RESEND_API_KEY="..."
CONTACT_TO_EMAIL=info@gv-hellas.ch
CONTACT_FROM_EMAIL="GV Hellas <gruezi@gv-hellas.ch>"
# - DeepL
TRANSLATE_MISSING_DE=true
DEEPL_API_KEY="..."
DEEPL_API_URL="https://api-free.deepl.com/v2/translate"

# Options
VITE_CMS_BASE_URL=/api/content# Built-in CMS API endpoint (same app)
VITE_CMS_TIMEOUT_MS=5000#Optional request timeout in milliseconds
SHARP_FORCE_GLOBAL_LIBVIPS=1