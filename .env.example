# Admin credentials for /admin
CMS_ADMIN_USER=admin
CMS_ADMIN_PASSWORD=password

# Services
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=to_email_here
CONTACT_FROM_EMAIL="from_name <from_email_here>"

# Options
VITE_CMS_BASE_URL=/api/content  # Built-in CMS API endpoint (same app)
VITE_CMS_TIMEOUT_MS=5000        # Optional request timeout in milliseconds
SHARP_FORCE_GLOBAL_LIBVIPS=1